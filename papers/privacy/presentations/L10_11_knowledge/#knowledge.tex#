\begin{itemize}
\item the theorem works only if the posterior is  \emph{common knowledge}
\item it is not enough that each player knows the posterior of the other:
  \begin{ex}
    \begin{itemize}
    \item $\Omega=\{\omega_1,\omega_2,\omega_3,\omega_4\}$
    \item prior: each state is equally likely
    \item $P_1$ partition: $\{(\omega_1,\omega_2),(\omega_3,\omega_4)\}$
   \item $P_2$ partition:  $\{(\omega_1,\omega_2,\omega_3),(\omega_4)\}$
   \item   $E=\{\omega_1,\omega_4\}$
   \item take $\omega'=\omega_1$, then:
     \begin{itemize}
     \item $\eta_1(E)=1/2$ and $\eta_2(E)=1/3$
     \item P1 knows that P2's information is  $(\omega_1,\omega_2,\omega_3)$ $\Ra$ P1 knows  $\eta_2(E)=1/3$
    \item P2 knows that player 1 either knows
       $(\omega_1,\omega_2)$ or knows $(\omega_3,\omega_4)$ and in
