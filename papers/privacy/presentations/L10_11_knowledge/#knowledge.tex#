\begin{prop}
  Suppose $G$ is a two player game and that in state $\omega$ each player $i\in N$ 
  \begin{itemize}
  \item knows the other player's belief: $P_i(\omega)\subseteq\{\omega':\mu_j(\omega')=\mu_j(\omega)\}$
  \item has a belief that is consistent with his knowledge: the support of $\mu_i(\omega)$ is a subset of $\{a_j(\omega'):\omega'\in P_i(\omega)\}$
  \item knows that the other player is rational: for any $\omega'\in P_i(\omega)$ the action $a_j(\omega')$ is a best reponse for player $j$ given his belief $\mu_j(\omega')$.
  \end{itemize}
Then the mixed strategy profile $(\mu_2(\omega),\mu_1(\omega))$ is a mixed strategy Nash equilibrium.
\end{prop}

\textbf{Proof. }Let $a_j^*$ be an action in the support of $\mu_i(\omega)$. To show: $a_j^*$ is a best response of player $j$ given his belief $\mu_j(\omega)$.
\dots% By the second bullet, there is a state $\omega'\in P_j(\omega)$ such that $a_i(\omega')=a_i^*$. By the third bullet, $a_i^*$ is best response of $i$ to $\mu_i(\omega')$ which by the first bullet is equal to $\mu_i(\omega)$. Hence, $a_i^*$ is a best response given $\mu_i(\omega)$.
\qed

