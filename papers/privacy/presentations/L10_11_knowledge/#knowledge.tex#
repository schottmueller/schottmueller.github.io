\subsection{Common knowledge}
\fr{\ft{Common knowledge}
For simplicity, we restrict ourselves to 2 player games. 
\begin{definition}
  Let $K_1$ and $K_2$ be the knowledge functions of player 1 and 2. An event $E\subseteq \Omega$ is \emph{common knowledge} between 1 and 2 in state $\omega$ if $\omega$ is a member of every set in the sequence $K_1(E)$, $K_2(E)$, $K_1(K_2(E))$, $K_2(K_1(E))$\dots.
\end{definition}

\begin{itemize}
\item $E$ is common knowledge if both players know and both players know that both players know and so on
\end{itemize}

\framebreak

\begin{definition}
  Let $P_1$ and $P_2$ be the information functions of the two players. An event $F$ is \emph{self-evident} between 1 and 2 if for all $\omega\in F$ we have $P_i(\omega)\subseteq F$ for $i=1,2$.\\
An event $E$ is \emph{common knowledge} between 1 and 2 in the state $\omega$ if there exists a self-evident set $F$ with $\omega\in F\subseteq E$. 
\end{definition}
\begin{itemize}
\item $F$ is self evident if \textbf{whenever} $F$ occurs (no matter which state $\omega\in F$) both players know that $F$ occurred \\(and because of this both players know that both players know \dots) 
% \item If such an $F$ is a subset of an event $E$, then
%   whenever a $\omega\in F$ occurs both players know that $E$ occurred
%   and thely also know that the other knows etc..
% \item if $F$ is self evident then $F=\cup_{\omega\in F}P_i(\omega)$ for both players\\ (for events $E$ that are \emph{not} self evident we have $E\subset\cup_{\omega\in E}P_i(\omega)$ for at least one player)
\end{itemize}

\framebreak

\begin{ex}
  \begin{itemize}
  \item
    $\Omega=\{\omega_1,\omega_2,\omega_3,\omega_4,\omega_5,\omega_6\}$
  \item $P_1=\{\{\omega_1,\omega_2\},\{\omega_3,\omega_4,\omega_5\},\{\omega_6\}\}$\\
    $P_2=\{\{\omega_1\},\{\omega_2,\omega_3,\omega_4\},\{\omega_5\},\{\omega_6\}\}$
\item Questions:    
\begin{itemize}
    \item Is the event
      $F=\{\omega_1,\omega_2,\omega_3,\omega_4,\omega_5\}$ self
      evident?
    \item In which states is $F$ common knowledge?
      % \begin{itemize}
      % \item $K_i(F)=F$
      % \end{itemize}
    \item Show that the event
      $E=\{\omega_1,\omega_2,\omega_3,\omega_4\}$ cannot be common
      knowledge in any state.
    \end{itemize}

    % \begin{itemize}
    % \item $K_1(E)=\{\omega_1,\omega_2\}$\\ $\Ra\;
    %   K_2(K_1(E))=K_2(\{\omega_1,\omega_2\})=\{\omega_1\}$\\
    %   $\Ra\;K_1(K_2(K_1(E)))=K_1(\{\omega_1\})=\emptyset$
    % \item alternatively: $E$ does not contain a subset $F$ that is
    %   self evident
    % \end{itemize}
  \end{itemize}
\end{ex}


\framebreak

Different interpretations of a ``self evident'' set $F$
\begin{itemize}
\item $F$ is self-evident between 1 and 2: \\
for any $\omega\in F$ we have $P_i(\omega)\subseteq F$ for $i=1,2$
\item this implies  $F=\cup_{\omega\in F}P_1(\omega)=\cup_{\omega\in F}P_2(\omega)$
\item it also means that we can write $F$ as union of a number of disjoint partition members of each $P_i$
\item and therefore $K_1(F)=K_2(F)=F$
\end{itemize}

% \textbf{Proof. }\dots% Assume (1). Then for every $\omega\in E$ we have $P_i(\omega)\subseteq E$. Hence (2). Assume (2). $E=\cup_{\omega\in E}P_i(\omega)$ for each $i=1,2$ and thus (3). Finally, (3) implies (1).
% \qed

\framebreak

\begin{prop}
  The two definitions of common knowledge are equivalent.
\end{prop}
\textbf{Proof. }% Assume $E$ is common knowledge in state $\omega$ according to the first definition. Note that $E\supseteq K_i(E)\supseteq K_j(K_i(E))\supseteq K_i(K_j(K_i(E)))\dots$, i.e. the knowledge operator make the set smaller as it comprises only those states of the original set where the corresponding information set is in the set. As $\Omega$ is finite, we must have a set $F_i=K_i(K_j(K_i \cdot\cdot\cdot K_i(E)\cdot\cdot\cdot)$ for which $K_j(F_i)=F_i$. By (K4) and (K5), we also have $K_i(F_i)=F_i$ and therefore $F_i$ is self evident which leads to the second definition.\\
% Now assume $E$ is common knowledge according to the second definition. Let $F$ be the self evident set. Then $F=K_i(K_j(K_i \cdot\cdot\cdot K_i(F)\cdot\cdot\cdot)$. Therefore, any set of the form $K_i(K_j(K_i \cdot\cdot\cdot K_i(E)\cdot\cdot\cdot)$ will include $F$. As $\omega\in F$, this leads to the first definition.
\qed
