 \subsection{Aumann's model of knowledge}

\fr{\ft{A model of knowledge}
  \begin{itemize}
  \item \emph{finite} set of states $\Omega$
  \item \emph{information function} $P$ assigning to each $\omega\in\Omega$ a non-empty subset of $\Omega$ ($P:\omega\ra 2^\Omega$) such that
    \begin{itemize}
    \item (P1) $\omega\in P(\omega)$ for every $\omega\in\Omega$
    \item  (P2) if $\omega'\in P(\omega)$ then $P(\omega)=P(\omega')$
    \end{itemize}
 i.e.  information function is \emph{partitional}
 
\begin{ex}
  Let $\Omega=[0,1)$. The decision maker observes only the first digit of $\omega$. In this case, the partition is $\{[0,0.1),[0.1,0.2),\dots,[0.9,1)\}$.
\end{ex}

