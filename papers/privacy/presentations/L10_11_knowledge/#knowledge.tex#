  \begin{itemize}
  \item common prior belief is $\rho$ (probability measure on $\Omega$)
  \item $\rho(E|P_i(\omega))$ is the posterior probability player $i$ assigns to event $E$ in state $\omega$
  \item the event ``player $i$ assigns probability $\eta_i$ to event $E$'' is the set of states $\{\omega: \rho(E|P_i(\omega)=\eta_i\}$.
  \end{itemize}

