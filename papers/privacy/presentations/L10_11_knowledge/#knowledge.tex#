   \begin{itemize}
   \item $a_i(\omega)\in A_i$ the action chosen by player $i$ in state
     $\omega$
   \item $\mu_i(\omega)$ a probability measure over $A_{-i}$, the
     belief player $i$ holds over the other player's actions.
   \item $P_i(\omega)\subseteq \Omega$ the player's knowledge (using a
     partitional information function)
   \end{itemize}
 \end{itemize}

